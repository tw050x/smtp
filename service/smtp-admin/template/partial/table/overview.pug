div(
  id="dashboard-content"
  hx-get="/admin/dashboard"
  hx-trigger=`load delay:${onLoadDelayInSeconds}s`
  hx-swap="outerHTML"
)
  div(class="flex flex-col border border-gray-300 rounded-md mt-4")
    div(class="flex px-4 py-2 font-bold")
      div(class="flex-1 text-left") Last 24 Hours
    div(class="flex px-4 py-6")
      div(class="flex-1 text-left")
        div(class="text-sm text-gray-500") Total Connections
        div(class="text-2xl font-bold") #{totalConnections24Hours}

  div(class="flex flex-col border border-gray-300 rounded-md mt-4")
    div(class="flex px-4 py-2 font-bold")
      div(class="flex-1 text-left") All Time
    div(class="flex px-4 py-6")
      div(class="flex-1 text-left")
        div(class="text-sm text-gray-500") Total Connections
        div(class="text-2xl font-bold") #{totalConnectionsAllTime}

  div(class="circular-loader-container")
    svg(viewBox="0 0 36 36")
      circle(cx="18" cy="18" r="16")

  style.
    @keyframes circular-loader {
      0% {
        stroke-dasharray: 0, 100;
      }
      100% {
        stroke-dasharray: 100, 0;
      }
    }

    .circular-loader-container {
      width: 10px;
      height: 10px;
      display: inline-block;
      position: absolute;
      top: 10px;
      right: 10px;
    }

    .circular-loader-container svg {
      transform: rotate(-90deg);
    }

    .circular-loader-container circle {
      fill: none;
      stroke: #9ca3af;
      stroke-width: 8;
      stroke-dasharray: 0, 100;
      animation: circular-loader #{onLoadDelayInSeconds}s linear infinite;
    }
